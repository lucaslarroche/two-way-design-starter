# Figma personal access token
# Generate at: https://www.figma.com/settings → Personal access tokens
FIGMA_TOKEN=

# Full URL of your Figma file
FIGMA_FILE_URL=https://www.figma.com/file/REPLACE_WITH_YOUR_FILE_ID/two-way-design-starter

# Just the file ID portion (the string between /file/ and the next slash in the URL above)
FIGMA_FILE_ID=REPLACE_WITH_YOUR_FILE_ID
